---
import Layout from "@/components/layout/layout.astro";
import { TextFade } from "@/components/motion/text-fade";
import { PROJECTS, SKILLS } from "@/features/portfolio/constants";
import { ProjectCard } from "@/features/portfolio/components/project-card";
---

<Layout title="Portfolio | Friedrich WT">
  <main class="flex flex-1 items-start justify-center py-2">
    <section
      class="flex w-1/2 flex-col items-start justify-center gap-8 pt-8 max-xl:w-2/3 max-sm:w-[90%]"
    >
      <h2 class="w-full text-start text-4xl font-extrabold">Projects</h2>
      <TextFade client:load direction="up">
        <div class="flex flex-col gap-8">
          {
            PROJECTS.map((project, index) => (
              <ProjectCard project={project} index={index} client:load />
            ))
          }
        </div>
      </TextFade>

      <h2 class="w-full text-start text-4xl font-extrabold">Skills</h2>

      <div class="w-full">
        <TextFade client:load direction="up">
          <ul class="flex w-full flex-wrap items-center justify-start gap-3">
            {
              SKILLS.map(({ tech, logo: Logo }) => (
                <li class="flex items-center justify-center gap-2 rounded-md border p-2">
                  <Logo class="size-5.5" />
                  <span>{tech}</span>
                </li>
              ))
            }
          </ul>
        </TextFade>
      </div>
    </section>
  </main>
</Layout>
